{
  "name": "spare-qa-producthunt-assignment",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test:api": "bun test tests/api/core.test.ts",
    "test:api:extended": "bun test tests/api",
    "test:e2e": "playwright test --project=chromium --grep @core",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:extended": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --grep @core",
    "test:e2e:ui": "playwright test --ui",
    "report": "playwright show-report",
    "pw:install": "playwright install --with-deps chromium",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.2.18",
    "typescript": "^5.8.3"
  }
}
